NODE_ENV=production
PORT=3000
PGHOST=postgres
PGUSER=crm
PGPASSWORD=crm
PGDATABASE=recoversuite
PGPORT=5432
PG_POOL_MAX=20
PG_IDLE_TIMEOUT_MS=30000
PG_CONN_TIMEOUT_MS=2000
PG_STATEMENT_TIMEOUT_MS=0
PG_KEEPALIVE_MS=10000
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_RETRY_DELAY_MS=500
REDIS_MAX_RETRY_DELAY_MS=5000
CACHE_SEARCH_TTL_SECONDS=30
CACHE_CLIENT_DETAIL_TTL_SECONDS=60
CACHE_CATALOG_TTL_SECONDS=300
QUEUE_NAME=crm-jobs
QUEUE_CONCURRENCY=10
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY_MS=3000
QUEUE_LOCK_DURATION_MS=30000
QUEUE_MAX_STALLED_COUNT=2
QUEUE_JOB_TIMEOUT_MS=0
QUEUE_REMOVE_ON_COMPLETE_COUNT=1000
QUEUE_REMOVE_ON_COMPLETE_AGE_SECONDS=3600
QUEUE_REMOVE_ON_FAIL_COUNT=5000
QUEUE_REMOVE_ON_FAIL_AGE_SECONDS=86400
QUEUE_MAX_ACTIVE=4
QUEUE_LOCK_TTL_MS=600000
QUEUE_LOCK_RENEW_INTERVAL_MS=10000
QUEUE_LOCK_RETRY_DELAY_MS=5000
QUEUE_RATE_LIMIT_MAX=0
QUEUE_RATE_LIMIT_DURATION_MS=0
UPLOAD_DIR=storage/uploads
UPLOAD_MAX_MB=50
BULK_IMPORT_BATCH_SIZE=200
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-refresh
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=recoversuite
JWT_AUDIENCE=recoversuite-web
JWT_ALGORITHM=HS256
AUTH_ADMIN_ID=admin
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=ChangeMe123!
PASSWORD_SALT_ROUNDS=12
